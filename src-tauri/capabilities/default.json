{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permisos por defecto de la app",
  "windows": ["main", "panel-config"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:window:allow-close",
    "core:webview:allow-create-webview-window",


    "sql:default",
    "sql:allow-execute",

    "dialog:default",
    "fs:default",
    "fs:write-all",
    {
      "identifier": "fs:allow-read-file",
      "allow": ["$APPDATA/pollos.db"]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": ["$APPDATA/pollos.db"]
    },
    "shell:default",
    "opener:default",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "https://*.googleapis.com/*" }]
    },
    {
      "identifier": "http:allow-fetch-send",
      "allow": [{ "url": "https://*.googleapis.com/*" }]
    }

  ]
}