{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permisos por defecto de la app",
  "windows": ["main", "panel-config"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",

    "sql:default",
    "sql:allow-execute",

    "dialog:default",
    "fs:default",
    "fs:write-all",
    "shell:default",
    "opener:default"
  ]
}